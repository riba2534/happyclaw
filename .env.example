# HappyClaw production environment template
# Copy to .env.production and adjust for your host.

NODE_ENV=production
WEB_PORT=3000
ASSISTANT_NAME=HappyClaw
TRUST_PROXY=true
TZ=Asia/Shanghai

# Optional: override Python used for native module builds.
# PYTHON_FOR_BUILD=/home/your-user/.local/python-3.11.11/bin/python3

# Optional: override native build toolchain for node-gyp modules.
# CC=clang-11
# CXX=clang++-11

# Optional: override generated/persisted session secret.
# WEB_SESSION_SECRET=replace-with-a-64-char-random-string

# Optional: allow specific origins for cross-origin API access.
# Leave empty for same-origin access behind reverse proxy.
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_LOCALHOST=false

# Runtime limits
CONTAINER_IMAGE=happyclaw-agent:latest
CONTAINER_TIMEOUT=1800000
IDLE_TIMEOUT=1800000
CONTAINER_MAX_OUTPUT_SIZE=10485760
MAX_CONCURRENT_CONTAINERS=20
MAX_CONCURRENT_HOST_PROCESSES=5
MAX_CONCURRENT_SCRIPTS=5
SCRIPT_TIMEOUT=300000
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Optional Claude provider bootstrap values.
# The Web setup wizard remains the preferred configuration path.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
CLAUDE_CODE_OAUTH_TOKEN=
HAPPYCLAW_MODEL=

# Optional IM provider bootstrap values.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY_URL=
